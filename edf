#include <stdio.h>

#define MAX 10

typedef struct {
    int id, arrival, burst, deadline;
    int remaining, completed;
} Process;

int main() {
    Process p[MAX];
    int n, time = 0, done = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        printf("\nProcess %d\n", i + 1);
        p[i].id = i + 1;

        printf("Arrival Time: ");
        scanf("%d", &p[i].arrival);

        printf("Burst Time: ");
        scanf("%d", &p[i].burst);

        printf("Deadline: ");
        scanf("%d", &p[i].deadline);

        p[i].remaining = p[i].burst;
        p[i].completed = 0;
    }

    printf("\nExecution:\n");

    while (done < n) {
        int idx = -1, min_deadline = 1e9;

        for (int i = 0; i < n; i++) {
            if (p[i].arrival <= time && !p[i].completed) {
                if (p[i].deadline < min_deadline) {
                    min_deadline = p[i].deadline;
                    idx = i;
                }
            }
        }

        if (idx != -1) {
            printf("P%d ", p[idx].id);
            p[idx].remaining--;
            time++;

            if (p[idx].remaining == 0) {
                p[idx].completed = 1;
                done++;
            }
        } else {
            printf("Idle ");
            time++;
        }
    }

    return 0;
}